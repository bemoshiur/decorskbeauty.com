# Decor's K-Beauty — environment template
# Copy to .env.local. Never commit real values.

# ── Core ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://decorskbeauty.com
PAYLOAD_SECRET=
DATABASE_URL=                      # Neon POOLED string (must be the -pooler host)
BLOB_READ_WRITE_TOKEN=

# ── EPS ──────────────────────────────────────────────────────────────
# dev: Public Pulse Agency sandbox creds. prod: Decor's own merchant creds.
EPS_MODE=sandbox                   # sandbox | production
EPS_MERCHANT_ID=
EPS_STORE_ID=
EPS_USERNAME=
EPS_PASSWORD=
EPS_HASH_KEY=
EPS_SUCCESS_URL=https://decorskbeauty.com/api/payments/eps/success
EPS_FAIL_URL=https://decorskbeauty.com/api/payments/eps/fail
EPS_CANCEL_URL=https://decorskbeauty.com/api/payments/eps/cancel

# ── Pathao (primary courier) ─────────────────────────────────────────
PATHAO_BASE_URL=https://api-hermes.pathao.com
# sandbox: https://courier-api-sandbox.pathao.com
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
PATHAO_USERNAME=
PATHAO_PASSWORD=
PATHAO_STORE_ID=

# ── Steadfast (fallback courier) ─────────────────────────────────────
STEADFAST_BASE_URL=https://portal.packzy.com/api/v1
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=
STEADFAST_WEBHOOK_TOKEN=

# ── Fraud / success-rate check ───────────────────────────────────────
FRAUD_PROVIDER=pathao              # pathao | fraudbd | null
FRAUDBD_API_KEY=                   # only if FRAUD_PROVIDER=fraudbd

# ── Meta ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=
META_DATASET_ID=
META_CAPI_ACCESS_TOKEN=
META_GRAPH_VERSION=                # pin current stable; check Meta's changelog, do not guess
META_TEST_EVENT_CODE=              # dev only. MUST be empty in production.
META_CATALOG_ID=

# ── SMS ──────────────────────────────────────────────────────────────
SMS_PROVIDER=gennet                # gennet | alpha | console
GENNET_BASE_URL=                   # TODO: pull from the Gennet merchant panel
GENNET_API_KEY=
GENNET_SENDER_ID=DecorsKB
ALPHA_SMS_API_KEY=                 # fallback: https://api.sms.net.bd/sendsms

# ── Email ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=orders@decorskbeauty.com

# ── Security ─────────────────────────────────────────────────────────
JWT_SECRET=                        # signs in-app-browser resume tokens
CRON_SECRET=

# ── Analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_GA4_ID=
GA4_API_SECRET=
